{
  "entities": {
    "response": {
      "title": "Survey Response",
      "description": "A single survey submission from a Client evaluating their VA.",
      "type": "object",
      "properties": {
        "user_type": { "type": "string", "enum": ["Virtual Assistant (Medical & Business)", "Support Team"] },
        "full_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "practice_type": { "type": "string" },
        "va_count": { "type": "string" },
        "sections": { "type": "object" },
        "submitted_at": { "type": "string", "format": "date-time" },
        "is_additional_role": { "type": "boolean" }
      },
      "required": ["user_type", "full_name", "email", "role", "practice_type", "va_count", "sections", "submitted_at"]
    },
    "user": {
      "title": "User Profile",
      "description": "A user profile with role-based access control.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "responder"] }
      },
      "required": ["email", "role"]
    },
    "test_connection": {
      "title": "Connection Test",
      "description": "A simple document to test Firestore connectivity.",
      "type": "object",
      "properties": {
        "status": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/responses/{responseId}": {
      "schema": "response",
      "description": "A collection of survey responses."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "A collection of user profiles for access control."
    },
    "/test/connection": {
      "schema": "test_connection",
      "description": "A document used to test connectivity."
    }
  }
}
